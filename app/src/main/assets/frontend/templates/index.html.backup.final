<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>TPV Ultra Smart</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:system-ui,-apple-system,sans-serif;background:linear-gradient(135deg,#0d1b2a 0%,#1a3a5c 55%,#0d6efd 100%);min-height:100vh;color:white}
.login-card{background:rgba(255,255,255,0.95);border-radius:1.5rem;padding:2rem;max-width:400px;width:95%;margin:2rem auto;color:#1e293b;box-shadow:0 20px 60px rgba(0,0,0,0.3)}
.btn{display:inline-block;padding:0.75rem 1.5rem;border:none;border-radius:0.75rem;font-weight:600;cursor:pointer;text-align:center}
.btn-primary{background:#0d6efd;color:white}
.btn-success{background:#198754;color:white}
.btn-danger{background:#dc3545;color:white}
.form-control{width:100%;padding:0.75rem;border:2px solid #e2e8f0;border-radius:0.75rem;font-size:1rem;margin-bottom:1rem}
.app-screen{display:none;padding:1rem}
.tab-content{background:rgba(255,255,255,0.9);border-radius:0.5rem;padding:1rem;color:#1e293b;min-height:200px;margin-top:1rem}
.product-item{background:white;border-radius:0.5rem;padding:0.75rem;margin-bottom:0.5rem;display:flex;justify-content:space-between;align-items:center}
.stock{font-size:0.7rem;padding:2px 6px;border-radius:4px}
.stock-verde{background:#22c55e;color:white}.stock-amarillo{background:#eab308;color:black}.stock-rojo{background:#ef4444;color:white}
.nav-tabs{display:flex;gap:0.5rem;margin-bottom:1rem;overflow-x:auto;padding-bottom:0.5rem}.nav-tab{padding:0.5rem 1rem;background:rgba(255,255,255,0.1);border-radius:0.5rem;color:white;white-space:nowrap;border:none}.nav-tab.active{background:#0d6efd}
</style>
</head>
<body>
<!-- LOGIN -->
<div id="login-screen" style="display:flex;align-items:center;justify-content:center;min-height:100vh;padding:1rem">
  <div class="login-card text-center">
    <h3 style="margin-bottom:1rem">🏪 TPV Ultra Smart</h3>
    <p style="margin-bottom:1.5rem;color:#64748b">Sistema Punto de Venta</p>
    <input type="text" id="username" class="form-control" placeholder="Usuario (desarrollador)">
    <input type="password" id="password" class="form-control" placeholder="Contraseña (dev2024)">
    <button class="btn btn-primary" style="width:100%" onclick="login()">Entrar</button>
    <p id="msg" style="margin-top:1rem;color:#dc2626;font-size:0.875rem"></p>
  </div>
</div>

<!-- APP PRINCIPAL -->
<div id="app-screen" class="app-screen">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem">
    <h5 style="margin:0">👋 Bienvenido, <span id="user-name"></span></h5>
    <button class="btn" style="background:rgba(255,255,255,0.2);color:white;border-radius:0.5rem" onclick="logout()">Salir</button>
  </div>
  
  <!-- Pestañas -->
  <div class="nav-tabs">
    <button class="nav-tab active" onclick="switchTab('catalogo')">📦 Catálogo</button>
    <button class="nav-tab" onclick="switchTab('orden')">🛒 Orden</button>
    <button class="nav-tab" onclick="switchTab('ventas')">📊 Ventas</button>
  </div>
  
  <!-- Catálogo -->
  <div id="tab-catalogo" class="tab-content">
    <input type="text" id="buscador" class="form-control" placeholder="Buscar producto..." oninput="filtrarProductos()" style="margin-bottom:0.5rem">
    <div id="productos-lista"></div>
  </div>
  
  <!-- Orden -->
  <div id="tab-orden" class="tab-content" style="display:none">
    <div id="orden-items" style="margin-bottom:1rem"></div>
    <div style="display:flex;justify-content:space-between;font-weight:bold;margin-bottom:0.5rem">
      <span>Total:</span><span id="orden-total">$0.00</span>
    </div>
    <button class="btn btn-success" style="width:100%" onclick="procesarPago()">💰 Procesar Pago</button>
  </div>
  
  <!-- Ventas -->
  <div id="tab-ventas" class="tab-content" style="display:none">
    <div id="ventas-lista"></div>
  </div>
</div>

<!-- JS EMBEBIDO - TODO EN UNO -->
<script>
// Estado global
let state={productos:[],orden:[],ventas:{}};
let auth=null;

// Login
async function login(){
  const u=document.getElementById('username').value.trim();
  const p=document.getElementById('password').value;
  const msg=document.getElementById('msg');
  if(!u||!p){msg.textContent='Completa usuario y contraseña';return}
  msg.textContent='Verificando...';
  try{
    const r=await fetch('/api/auth/login',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({username:u,password:p})});
    const d=await r.json();
    if(d.ok){
      auth=d.usuario;
      document.getElementById('login-screen').style.display='none';
      document.getElementById('app-screen').style.display='block';
      document.getElementById('user-name').textContent=d.usuario.nombre;
      await cargarProductos();
      renderizarTodo();
    }else msg.textContent=d.error||'Error';
  }catch(e){msg.textContent='Error de conexión'}
}

// Logout
async function logout(){
  try{await fetch('/api/auth/logout',{method:'POST'})}catch(e){}
  auth=null;state.orden=[];
  document.getElementById('app-screen').style.display='none';
  document.getElementById('login-screen').style.display='flex';
  document.getElementById('username').value='';
  document.getElementById('password').value='';
  document.getElementById('msg').textContent='';
}

// Cargar productos desde API
async function cargarProductos(){
  try{
    const r=await fetch('/api/catalogo');
    if(r.ok){const d=await r.json();if(d.ok)state.productos=d.productos}
  }catch(e){console.log('Offline')}
}

// Renderizar catálogo
function renderizarProductos(){
  const lista=document.getElementById('productos-lista');
  const filtro=document.getElementById('buscador')?.value.toLowerCase()||'';
  const prods=state.productos.filter(p=>p.nombre.toLowerCase().includes(filtro));
  if(!prods.length){lista.innerHTML='<p style="text-align:center;color:#64748b;padding:1rem">Sin productos</p>';return}
  lista.innerHTML=prods.map(p=>{
    const stock=p.stock||0;
    const color=stock>=24?'verde':stock>=15?'amarillo':'rojo';
    return `<div class="product-item">
      <div><strong>${p.nombre}</strong><br><small style="color:#64748b">${p.categoria||'General'}</small></div>
      <div style="text-align:right">
        <div style="font-weight:bold;color:#16a34a">$${(p.precio||0).toFixed(2)}</div>
        <span class="stock stock-${color}">${stock} uds</span>
      </div>
      <button class="btn btn-primary" style="margin-left:0.5rem;padding:0.25rem 0.75rem" onclick="agregar('${p.id}')">+</button>
    </div>`;
  }).join('');
}

function filtrarProductos(){renderizarProductos()}

// Agregar a orden
function agregar(id){
  const prod=state.productos.find(p=>p.id===id);
  if(!prod)return;
  const ex=state.orden.find(i=>i.id===id);
  if(ex)ex.cant=(ex.cant||1)+1;else state.orden.push({...prod,cant:1});
  renderizarOrden();
}

// Renderizar orden
function renderizarOrden(){
  const items=document.getElementById('orden-items');
  const total=document.getElementById('orden-total');
  if(!state.orden.length){items.innerHTML='<p style="text-align:center;color:#64748b">Orden vacía</p>';total.textContent='$0.00';return}
  let t=0;
  items.innerHTML=state.orden.map((it,idx)=>{
    const sub=(it.precio||0)*(it.cant||1);t+=sub;
    return `<div style="display:flex;justify-content:space-between;align-items:center;padding:0.5rem 0;border-bottom:1px solid #e2e8f0">
      <span>${it.nombre} ×${it.cant}</span>
      <div>
        <span style="font-weight:bold">$${sub.toFixed(2)}</span>
        <button class="btn" style="background:#ef4444;color:white;margin-left:0.5rem;padding:0.1rem 0.5rem;border-radius:0.25rem" onclick="quitar(${idx})">×</button>
      </div>
    </div>`;
  }).join('');
  total.textContent=`$${t.toFixed(2)}`;
}

function quitar(idx){state.orden.splice(idx,1);renderizarOrden()}

// Procesar pago
async function procesarPago(){
  if(!state.orden.length)return alert('Orden vacía');
  const hoy=new Date().toISOString().split('T')[0];
  const ventas=state.orden.map(it=>({id:`v-${Date.now()}-${Math.random()}`,productoId:it.id,nombre:it.nombre,cantidad:it.cant,precioUnitario:it.precio,total:(it.precio||0)*(it.cant||1),fecha:new Date().toISOString(),metodoPago:'efectivo'}));
  state.ventas[hoy]=state.ventas[hoy]||[];
  state.ventas[hoy].push(...ventas);
  try{await fetch('/api/state',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(state)})}catch(e){}
  state.orden=[];renderizarOrden();renderizarVentas();
  alert('✅ Venta procesada');
}

// Renderizar ventas
function renderizarVentas(){
  const lista=document.getElementById('ventas-lista');
  const hoy=new Date().toISOString().split('T')[0];
  const vs=state.ventas[hoy]||[];
  if(!vs.length){lista.innerHTML='<p style="text-align:center;color:#64748b">Sin ventas hoy</p>';return}
  lista.innerHTML=vs.map(v=>`<div style="display:flex;justify-content:space-between;padding:0.5rem 0;border-bottom:1px solid #e2e8f0"><span>${v.nombre} ×${v.cantidad}</span><span style="font-weight:bold;color:#16a34a">$${(v.total||0).toFixed(2)}</span></div>`).join('');
}

// Renderizar todo
function renderizarTodo(){renderizarProductos();renderizarOrden();renderizarVentas()}

// Cambiar pestaña
function switchTab(tab){
  ['catalogo','orden','ventas'].forEach(t=>{
    document.getElementById('tab-'+t).style.display=t===tab?'block':'none';
    document.querySelectorAll('.nav-tab')[['catalogo','orden','ventas'].indexOf(t)].classList.toggle('active',t===tab);
  });
}

// Inicializar al cargar
document.addEventListener('DOMContentLoaded',async()=>{
  try{
    const r=await fetch('/api/auth/me');
    if(r.ok){const d=await r.json();if(d.autenticado){auth=d.usuario;document.getElementById('login-screen').style.display='none';document.getElementById('app-screen').style.display='block';document.getElementById('user-name').textContent=d.usuario.nombre;await cargarProductos();renderizarTodo()}}
  }catch(e){}
});
</script>
</body>
</html>
