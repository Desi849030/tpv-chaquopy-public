#!/data/data/com.termux/files/usr/bin/bash

SERVICE_NAME="TPV Frontend"
PORT=8080
FRONTEND_DIR="$HOME/tpv-chaquopy/app/src/main/assets/frontend"
LOGFILE="$HOME/tpv-chaquopy/tpv.log"

start() {
    echo "Iniciando servicio..."
    cd "$FRONTEND_DIR"
    nohup python3 -m http.server $PORT > "$LOGFILE" 2>&1 &
    echo "Servidor iniciado en http://127.0.0.1:$PORT"
}

stop() {
    echo "Deteniendo servicio..."
    killall python3 2>/dev/null || true
    killall python3.13 2>/dev/null || true
    killall python 2>/dev/null || true
    tmux kill-server 2>/dev/null || true
    echo "Servicio detenido."
}

status() {
    echo "Verificando estado..."
    if lsof -i:$PORT >/dev/null 2>&1; then
        PID=$(lsof -t -i:$PORT)
        echo "TPV corriendo (PID $PID)"
    else
        echo "TPV detenido"
    fi
}

logs() {
    tail -f "$LOGFILE"
}

case "$1" in
    start) start ;;
    stop) stop ;;
    restart) stop; start ;;
    status) status ;;
    logs) logs ;;
    *) echo "Uso: tpv {start|stop|restart|status|logs}" ;;
esac
