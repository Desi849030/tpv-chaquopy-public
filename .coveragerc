[run]
source = app/src/main/python
omit =
    # Requieren cloud (Supabase)
    */supabase_sync*
    */supabase_rls*
    */sync/*
    */modules/settings_supabase*
    */modules/debug_sync*
    # Requieren hardware (telecom, biometría)
    */security_attestation*
    */security_websocket*
    */modules/telecom_diag*
    */modules/telecom_bp*
    */biometric_auth*
    # Legacy IA no usado por el nuevo agente
    */ia/humanizer*
    */ia/skills*
    */ia/role_guidance*
    */ia/session_context*
    */ia/guide_manager*
    */ia/db_utils*
    */ia/fuzzy_match*
    */ia/metrics*
    */ia/react_templates*
    */ia/react_categories*
    */ia/react_plans*
    */ia/context_memory*
    */state*

[report]
exclude_lines =
    pragma: no cover
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    except ImportError:
    except Exception:
    raise NotImplementedError
