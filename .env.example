# TPV Ultra Smart — Variables de entorno
# Copia este archivo a .env y edita los valores

# Password para usuarios demo (admin, cajero1, vendedor1, etc.)
# Si no se establece, se usa "demo-tpv-2026"
# IMPORTANTE: cambia esto en producción
TPV_DEMO_PASSWORD=demo-tpv-2026

# Puerto del backend Flask (default: 5050)
TPV_PORT=5050

# Directorio del frontend (opcional, auto-detectado si no se establece)
# TPV_FRONTEND_DIR=

# Modo testing (desactiva algunas verificaciones de seguridad)
# TPV_TESTING=1

# HTTPS (para cookies seguras)
# TPV_HTTPS=1

# Secret key de Flask (cambiar en producción)
# TPV_SECRET_KEY=tpv-ultra-smart-v8-CAMBIAR-EN-PRODUCCION

# Supabase (opcional, para sync cloud)
# SUPABASE_URL=
# SUPABASE_KEY=
