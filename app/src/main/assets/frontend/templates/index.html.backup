<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TPV Smart v13.0</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
            background: linear-gradient(135deg, #0c0c1d 0%, #1a1a3e 50%, #0f3460 100%);
            color: white;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }
        .container {
            background: rgba(255,255,255,0.05);
            backdrop-filter: blur(20px);
            border-radius: 24px;
            border: 1px solid rgba(255,255,255,0.1);
            padding: 30px;
            max-width: 800px;
            width: 100%;
            box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5);
        }
        .header {
            text-align: center;
            margin-bottom: 30px;
        }
        .header h1 {
            font-size: 2.5em;
            background: linear-gradient(135deg, #00d4ff, #00ff88);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .header .subtitle {
            color: #8892b0;
            font-size: 0.9em;
            margin-top: 5px;
        }
        .badge-container {
            display: flex;
            justify-content: center;
            gap: 10px;
            margin: 15px 0;
            flex-wrap: wrap;
        }
        .badge {
            display: inline-block;
            padding: 4px 14px;
            border-radius: 20px;
            font-size: 0.75em;
            font-weight: 600;
            background: rgba(0, 255, 136, 0.15);
            color: #00ff88;
            border: 1px solid rgba(0, 255, 136, 0.2);
        }
        .badge.ia {
            background: rgba(255, 107, 107, 0.15);
            color: #ff6b6b;
            border-color: rgba(255, 107, 107, 0.2);
        }
        .login-form {
            background: rgba(0,0,0,0.3);
            border-radius: 16px;
            padding: 25px;
            margin-bottom: 20px;
            display: none;
        }
        .login-form.active {
            display: block;
        }
        .login-form input {
            width: 100%;
            padding: 12px 16px;
            margin: 8px 0;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 12px;
            color: white;
            font-size: 1em;
            transition: all 0.3s;
        }
        .login-form input:focus {
            outline: none;
            border-color: #00d4ff;
            background: rgba(255,255,255,0.08);
        }
        .login-form input::placeholder {
            color: #666;
        }
        .login-form button {
            width: 100%;
            padding: 14px;
            margin-top: 12px;
            background: linear-gradient(135deg, #00d4ff, #00ff88);
            border: none;
            border-radius: 12px;
            color: #0c0c1d;
            font-size: 1.1em;
            font-weight: 700;
            cursor: pointer;
            transition: transform 0.2s;
        }
        .login-form button:hover {
            transform: scale(1.02);
        }
        .login-form .error {
            color: #ff6b6b;
            font-size: 0.9em;
            margin-top: 10px;
            text-align: center;
        }
        .chat-container {
            display: none;
        }
        .chat-container.active {
            display: block;
        }
        .chat-messages {
            background: rgba(0,0,0,0.3);
            border-radius: 16px;
            padding: 20px;
            height: 350px;
            overflow-y: auto;
            margin-bottom: 15px;
            border: 1px solid rgba(255,255,255,0.05);
        }
        .chat-messages::-webkit-scrollbar {
            width: 4px;
        }
        .chat-messages::-webkit-scrollbar-track {
            background: rgba(255,255,255,0.05);
            border-radius: 10px;
        }
        .chat-messages::-webkit-scrollbar-thumb {
            background: #00d4ff;
            border-radius: 10px;
        }
        .message {
            margin-bottom: 12px;
            padding: 12px 16px;
            border-radius: 12px;
            max-width: 85%;
            word-wrap: break-word;
            animation: fadeIn 0.3s ease;
        }
        .message.user {
            background: linear-gradient(135deg, #00d4ff, #0088cc);
            margin-left: auto;
            color: white;
        }
        .message.assistant {
            background: rgba(255,255,255,0.08);
            margin-right: auto;
            color: #e0e0e0;
        }
        .message .time {
            font-size: 0.7em;
            opacity: 0.5;
            margin-top: 5px;
            display: block;
        }
        .chat-input {
            display: flex;
            gap: 10px;
        }
        .chat-input input {
            flex: 1;
            padding: 14px 18px;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 12px;
            color: white;
            font-size: 1em;
            transition: all 0.3s;
        }
        .chat-input input:focus {
            outline: none;
            border-color: #00d4ff;
            background: rgba(255,255,255,0.08);
        }
        .chat-input input::placeholder {
            color: #666;
        }
        .chat-input button {
            padding: 14px 24px;
            background: linear-gradient(135deg, #00d4ff, #00ff88);
            border: none;
            border-radius: 12px;
            color: #0c0c1d;
            font-weight: 700;
            cursor: pointer;
            transition: transform 0.2s;
            white-space: nowrap;
        }
        .chat-input button:hover {
            transform: scale(1.05);
        }
        .chat-input button:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none;
        }
        .status-bar {
            display: flex;
            justify-content: space-between;
            padding: 10px 0;
            font-size: 0.8em;
            color: #666;
            border-top: 1px solid rgba(255,255,255,0.05);
            margin-top: 10px;
        }
        .status-bar .online {
            color: #00ff88;
        }
        .status-bar .offline {
            color: #ff6b6b;
        }
        .suggestions {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-top: 10px;
        }
        .suggestions button {
            padding: 6px 14px;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 20px;
            color: #8892b0;
            font-size: 0.8em;
            cursor: pointer;
            transition: all 0.3s;
        }
        .suggestions button:hover {
            background: rgba(0, 212, 255, 0.1);
            border-color: #00d4ff;
            color: white;
        }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .typing {
            color: #666;
            font-style: italic;
            padding: 8px 16px;
        }
        .user-info {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px 0;
            border-bottom: 1px solid rgba(255,255,255,0.05);
            margin-bottom: 15px;
        }
        .user-info .name {
            color: #00d4ff;
            font-weight: 600;
        }
        .user-info .logout {
            color: #ff6b6b;
            cursor: pointer;
            font-size: 0.9em;
            padding: 4px 12px;
            border: 1px solid rgba(255,107,107,0.2);
            border-radius: 8px;
            transition: all 0.3s;
        }
        .user-info .logout:hover {
            background: rgba(255,107,107,0.1);
        }
        @media (max-width: 600px) {
            .container { padding: 15px; }
            .header h1 { font-size: 1.8em; }
            .chat-messages { height: 250px; }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>🤖 TPV Smart</h1>
            <div class="subtitle">Asistente IA Offline v13.0</div>
            <div class="badge-container">
                <span class="badge">🔓 Bypass Activo</span>
                <span class="badge ia">⚡ Offline</span>
            </div>
        </div>

        <!-- Login -->
        <div class="login-form active" id="loginForm">
            <h3 style="margin-bottom: 15px; color: #8892b0;">🔐 Acceso al Sistema</h3>
            <input type="text" id="username" placeholder="Usuario (cualquiera)" value="admin">
            <input type="password" id="password" placeholder="Contraseña (cualquiera)" value="1234">
            <button onclick="login()">🚀 Iniciar Sesión</button>
            <div class="error" id="loginError"></div>
            <p style="text-align: center; color: #666; font-size: 0.8em; margin-top: 10px;">⚠️ Cualquier usuario/contraseña funciona</p>
        </div>

        <!-- Chat -->
        <div class="chat-container" id="chatContainer">
            <div class="user-info">
                <span class="name" id="userName">👤 Administrador</span>
                <span class="logout" onclick="logout()">🚪 Cerrar Sesión</span>
            </div>
            <div class="chat-messages" id="chatMessages">
                <div class="message assistant">
                    👋 ¡Hola! Soy tu asistente TPV.<br>
                    Pregúntame sobre ventas, productos, stock o lo que necesites.
                    <span class="time">Ahora</span>
                </div>
            </div>
            <div class="chat-input">
                <input type="text" id="chatInput" placeholder="Escribe tu pregunta..." onkeypress="if(event.key==='Enter') sendMessage()">
                <button onclick="sendMessage()">📤 Enviar</button>
            </div>
            <div class="suggestions" id="suggestions">
                <button onclick="sendSuggestion('ventas de hoy')">📊 Ventas hoy</button>
                <button onclick="sendSuggestion('stock bajo')">📦 Stock bajo</button>
                <button onclick="sendSuggestion('cuanto cuesta café')">☕ Precio café</button>
                <button onclick="sendSuggestion('ayuda')">❓ Ayuda</button>
            </div>
            <div class="status-bar">
                <span>🔗 <span class="online" id="statusIndicator">Conectado</span></span>
                <span id="userRole">Rol: Administrador</span>
            </div>
        </div>
    </div>

    <script>
        let token = null;
        let user = null;

        async function login() {
            const username = document.getElementById('username').value;
            const password = document.getElementById('password').value;
            const errorEl = document.getElementById('loginError');
            
            errorEl.textContent = '';
            
            try {
                const response = await fetch('/api/auth/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ username, password })
                });
                
                const data = await response.json();
                
                if (data.success) {
                    token = data.token;
                    user = data.user;
                    
                    document.getElementById('loginForm').classList.remove('active');
                    document.getElementById('chatContainer').classList.add('active');
                    document.getElementById('userName').textContent = `👤 ${user.name || user.username || 'Usuario'}`;
                    document.getElementById('userRole').textContent = `Rol: ${user.role || 'Administrador'}`;
                    
                    addMessage('assistant', `✅ ¡Bienvenido ${user.name || user.username}! ¿En qué puedo ayudarte?`);
                } else {
                    errorEl.textContent = '❌ Error al iniciar sesión';
                }
            } catch (error) {
                errorEl.textContent = '❌ Error de conexión con el servidor';
                console.error('Login error:', error);
            }
        }

        async function sendMessage() {
            const input = document.getElementById('chatInput');
            const message = input.value.trim();
            
            if (!message) return;
            
            input.value = '';
            input.disabled = true;
            
            addMessage('user', message);
            
            try {
                const response = await fetch('/api/agent/chat', {
                    method: 'POST',
                    headers: { 
                        'Content-Type': 'application/json',
                        'Authorization': token ? `Bearer ${token}` : ''
                    },
                    body: JSON.stringify({ 
                        message: message,
                        mensaje: message,
                        text: message
                    })
                });
                
                const data = await response.json();
                const reply = data.reply || data.response || data.message || data.text || 'No entendí tu pregunta.';
                addMessage('assistant', reply);
            } catch (error) {
                addMessage('assistant', '❌ Error de conexión. Intenta de nuevo.');
                console.error('Chat error:', error);
            } finally {
                input.disabled = false;
                input.focus();
            }
        }

        function sendSuggestion(text) {
            document.getElementById('chatInput').value = text;
            sendMessage();
        }

        function addMessage(type, text) {
            const container = document.getElementById('chatMessages');
            const div = document.createElement('div');
            div.className = `message ${type}`;
            
            const now = new Date();
            const timeStr = now.toLocaleTimeString();
            
            div.innerHTML = `${text}<span class="time">${timeStr}</span>`;
            container.appendChild(div);
            container.scrollTop = container.scrollHeight;
        }

        function logout() {
            token = null;
            user = null;
            document.getElementById('loginForm').classList.add('active');
            document.getElementById('chatContainer').classList.remove('active');
            document.getElementById('chatMessages').innerHTML = `
                <div class="message assistant">
                    👋 Sesión cerrada. Inicia sesión para continuar.
                    <span class="time">Ahora</span>
                </div>
            `;
        }

        // Check server status on load
        async function checkServer() {
            try {
                const response = await fetch('/api/health');
                if (response.ok) {
                    document.getElementById('statusIndicator').textContent = 'Conectado';
                    document.getElementById('statusIndicator').className = 'online';
                } else {
                    document.getElementById('statusIndicator').textContent = 'Error';
                    document.getElementById('statusIndicator').className = 'offline';
                }
            } catch {
                document.getElementById('statusIndicator').textContent = 'Desconectado';
                document.getElementById('statusIndicator').className = 'offline';
            }
        }
        
        // Auto-login (opcional)
        setTimeout(() => {
            // Si quieres login automático, descomenta:
            // login();
        }, 500);
        
        checkServer();
    </script>
</body>
</html>
