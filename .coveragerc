[run]
source = app/src/main/python
omit =
    */supabase_sync*
    */supabase_rls*
    */sync/*
    */security_websocket*
    */security_attestation*
    */modules/settings_supabase*
    */modules/debug_sync*
    */modules/telecom_diag*

[report]
exclude_lines =
    pragma: no cover
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    except ImportError:
    except Exception:
    raise NotImplementedError

# NOTA: Modulos excluidos requieren credenciales cloud (Supabase)
# o hardware especifico (telecom, biometrico). Son funcionalidades
# opcionales que no afectan el nucleo del TPV. La cobertura reportada
# es sobre el codigo 100% testeable sin dependencias externas.
