[run]
omit =
    app/src/main/python/ia/handlers_*.py
    app/src/main/python/ia/agent.py
    app/src/main/python/ia/context_memory.py
    app/src/main/python/ia/memory_*.py
    app/src/main/python/ia/react_*.py
    app/src/main/python/ia/skills.py
    app/src/main/python/ia/state.py
    app/src/main/python/license/*
    app/src/main/python/sync/*
    app/src/main/python/tools/*
    app/src/main/python/tests/*
    app/src/main/python/security/*
    app/src/main/python/response_validators/*
    app/src/main/python/metrics/*
    app/src/main/python/modules/telecom_*.py
    app/src/main/python/modules/tienda_*.py
    app/src/main/python/modules/ai_*.py
    */__init__.py
    app/src/main/python/ia/guardrails_v2.py
    app/src/main/python/ia/guardrails.py
    app/src/main/python/ia/guardrails_pro.py
    app/src/main/python/ia/humanizer.py

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    if self.debug:
    if __name__ == .__main__.:
    tests/oficial/test_auth_roles.py
